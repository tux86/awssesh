{
  "name": "ssomatic",
  "version": "1.3.0",
  "description": "AWS SSO credential manager with a terminal dashboard and background daemon — auto-refreshes starred profiles, expiry-aware, desktop notifications on login.",
  "keywords": [
    "aws",
    "sso",
    "aws-sso",
    "cli",
    "tui",
    "credentials",
    "daemon",
    "terminal",
    "ink",
    "bun"
  ],
  "type": "module",
  "license": "MIT",
  "bin": {
    "ssomatic": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18",
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "repository": {
    "type": "git",
    "url": "https://github.com/tux86/ssomatic.git"
  },
  "author": "tux86",
  "homepage": "https://github.com/tux86/ssomatic",
  "scripts": {
    "start": "bun run src/cli/index.tsx",
    "dev": "bun run --watch src/cli/index.tsx",
    "build": "bun build src/cli/index.tsx --target node --packages external --outfile dist/cli.js",
    "lint": "eslint src",
    "test": "bun test",
    "prepack": "bun run build",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-sso": "^3.1066.0",
    "@aws-sdk/client-sso-oidc": "^3.1066.0",
    "@aws-sdk/client-sts": "^3.1066.0",
    "ini": "^7.0.0",
    "ink": "^7.0.5",
    "ink-spinner": "^5.0.0",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.2.0",
    "@commitlint/config-conventional": "^20.2.0",
    "@eslint/js": "^10.0.1",
    "@types/ini": "^4.1.1",
    "@types/react": "^19.2.17",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "bun-types": "latest",
    "eslint": "^10.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "typescript": "^6.0.3"
  }
}
